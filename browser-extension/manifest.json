{
  "manifest_version": 3,
  "name": "Claude Code Web Assistant",
  "description": "Ask Claude Code Web about selected text or the current page from the Chrome side panel.",
  "version": "2.0.2",
  "permissions": ["activeTab", "contextMenus", "scripting", "sidePanel", "storage", "tabs"],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "options_page": "src/options.html",
  "action": {
    "default_title": "Claude Code Web"
  }
}
